{% extends "default.njk" %}
{%- css -%}
.flash {
    position: relative;
    &::before {
        content: '';
        width: 100%;
        height: 100%;
        position: absolute;
        background-image: linear-gradient(90deg, var(--blue), var(--bg));
        background-size: cover;
        z-index: -100;
        animation: flash ease-out 3000ms;
    }
}

@keyframes flash {
    0% {
        opacity: 1;
    }

    100% {
        opacity: 0;
    }
}

article {
    font-family: var(--type-serif);
    line-height: 1.5rem;

    img {
        display: block;
        width: 75%;
        height: auto;
        margin: 0 auto;
    }

    iframe {
        width: 100%;
        aspect-ratio: calc(16 / 9);
    }

    blockquote {
        margin: 0;
        padding: 1em 2em;
        border-left: 2px solid var(--blue);
        background-clip: padding-box;
        position: relative;
        &::before {
            content:'\201C';
            z-index: -100;
            position: absolute;
            transform: translateX(-25%) translateY(-25%);
            font-size:100pt;
            filter:opacity(0.2);
        }
    }

    .header-anchor-link {
        transition: all ease-in 200ms;
        color: var(--blue);
        opacity: 0;
    }


    h2:has(.header-anchor-link), h3:has(.header-anchor-link), h4:has(.header-anchor-link) {
        @media (hover: hover){
            &:hover {
                .header-anchor-link {
                    opacity: 1;
                }
            }
        }
    }
}

.post-banner img {
    width: 100%;
    object-fit: cover;
    aspect-ratio: calc(800 / 192);
    height: auto;
}

.post-description {
    display: block;
    margin: 1em auto;
}

.pagination-option {
    grid-row: 1;
}

.next-post {
    grid-column: 1;
    text-align: right;
}
.prev-post {
    grid-column: 3;
}
.pagination-arrow {
    color: var(--blue);
    font-size: 15pt;
}
{%- endcss -%}

{%- block head -%}
{% if headerImage.src %}
<meta property="og:image" content="{{ meta.base }}{{ headerImage.src | threshold(800, 192) or meta.banner }}">
<meta property="og:image:url" content="{{ meta.base }}{{ headerImage.src | threshold(800, 192) or meta.banner }}">
<meta property="og:image:alt" content="{{ headerImage.alt }}">
<meta property="og:description" content="{{ description }}">
<meta property="og:image:width" content=800>
<meta property="og:image:height" content=192>
{% endif %}
<link href="https://cdn.jsdelivr.net/npm/prismjs@1.30.0/themes/prism.min.css" rel="stylesheet" />
{{ super() }}
{% endblock head %}

{#
{% block sidebarLeft %}
{%- if content | toc -%}
<h4>Contents</h4>
{{ content | toc(tags=['h2']) | safe }}
{%- endif -%}
{% endblock sidebarLeft %}
#}

{% block content %}
<h1 class="post-title">{{ title }}</h1>
<small class="post-description">{{ description }}</small>
{% if headerImage.src %}
<picture class="post-banner">
<img eleventy:ignore src="{{ headerImage.src | threshold(500, 192) }}" alt="{{ headerImage.alt }}" loading="lazy" decoding="async" />
</picture>
{% endif %}
{{ macros.blogPostInfo({date: date, tags: topics}) }}
<hr />
{% if content | toc %}
<details open>
<summary>Contents</summary>
<div>{{ content | toc | safe }}</div>
</details>
{% endif %}
<article>
{{ super() }}
</article>
{% endblock content %}

{% block footer %}
{% set prevPost = collections.posts | getPreviousCollectionItem(page) %}
{% set nextPost = collections.posts | getNextCollectionItem(page) %}
{% if prevPost %}<div aria-label="Previous post" class="pagination-option prev-post"><a href="{{ prevPost.url }}">{{ prevPost.data.title }}</a><span class="pagination-arrow">==&gt;</span></div>{% endif %}
{% if nextPost %}<div aria-label="Next Post" class="pagination-option next-post"><span class="pagination-arrow">&lt;==</span><a href="{{ nextPost.url }}">{{ nextPost.data.title }}</a></div>{% endif %}
{{ super() }}
{% endblock footer %}

{% js %}
window.addEventListener("DOMContentLoaded", ()=>{
    document.querySelectorAll("nav.toc a").forEach(el=>{
        let timeoutHandle;
        const header = document.getElementById(el.getAttribute("href").slice(1));
        el.addEventListener("click", ()=>{
           if (!timeoutHandle) {
                header.classList.add("flash");
                timeoutHandle = setTimeout(()=>{
                    header.classList.remove("flash");
                    timeoutHandle = 0;
            }, 3000)
       } 
    })})
});
{% endjs %}
